{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "Basic Questionnaire Study",
        "version": "pilot",
        "authors": [
            "The reVISit Team",
            "You :)"
        ],
        "date": "2026-02-23",
        "description": "A simple questionnaire study",
        "organizations": [
            "University of Utah",
            "WPI"
        ]
    },
    "uiConfig": {
        "contactEmail": "your@email.com",
        "helpTextPath": "a3-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "baseComponents": {
        "bar-chart": {
            "type": "react-component",
            "path": "a3-study/assets/WrappedBarChart.tsx",
            "response": [
                {
                    "id": "bar-chart-resp",
                    "prompt": "Of the two marked bars, what proportion is the smaller bar of the larger bar?",
                    "type": "numerical",
                    "required": true
                }
            ]
        },
        "circ-areas": {
            "type": "react-component",
            "path": "a3-study/assets/WrappedCirclesAreas.tsx",
            "response": [
                {
                    "id": "circle-areas-resp",
                    "prompt": "Of the two marked circles, what proportion is the smaller circle of the larger circle by area?",
                    "type": "numerical",
                    "required": true
                }
            ]
        },
        "pie-areas": {
            "type": "react-component",
            "path": "a3-study/assets/WrappedPieChart.tsx",
            "response": [
                {
                    "id": "pie-areas-resp",
                    "prompt": "Of the two marked pie slices, what proportion is the smaller slice of the larger slice by area?",
                    "type": "numerical",
                    "required": true
                }
            ]
        },
        "square-areas": {
            "type": "react-component",
            "path": "a3-study/assets/WrappedSquareAreas.tsx",
            "response": [
                {
                    "id": "square-areas-resp",
                    "prompt": "Of the two marked squares, what proportion is the smaller square of the larger square by area?",
                    "type": "numerical",
                    "required": true
                }
            ]
        },
        "square-colors": {
            "type": "react-component",
            "path": "a3-study/assets/WrappedSquareColors.tsx",
            "response": [
                {
                    "id": "square-colors-resp",
                    "prompt": "Consider the saturations of the two marked rectangles. What proportion of the greater saturation is the lesser saturation? No saturation and full saturation are shown to the left for your reference.",
                    "type": "numerical",
                    "required": true
                }
            ]
        }
    },
    "components": {
        "introduction": {
            "type": "markdown",
            "path": "a3-study/assets/introduction.md",
            "response": []
        },
        "first-question-set": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "q1-name",
                    "prompt": "What is your first name?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "longText",
                    "placeholder": "Please enter your first name"
                },
                {
                    "id": "q2-color",
                    "prompt": "What is your favorite color?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "dropdown",
                    "placeholder": "Please choose your favorite color",
                    "options": ["Red", "Blue", "My favorite color is not shown here."]
                }
            ]
        },
        "second-question-set": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "q3-satisfaction",
                    "prompt": "Rate your satisfaction with this survey from 1 (not enjoyable) to 5 (very enjoyable).",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "likert",
                    "leftLabel": "Not Enjoyable",
                    "rightLabel": "Very Enjoyable",
                    "numItems": 5
                }
            ]
        },
        "training-bar-chart": {
            "baseComponent": "bar-chart",
            "parameters": {
                "data": [0.3, 0.4, 0.2, 0.1],
                "tags": [1, 2]
            },
            "correctAnswer": [{
                "answer": 0.5,
                "acceptableHigh": 0.4,
                "acceptableLow": 0.6,
                "id": "bar-chart-resp"
            }],
            "allowFailedTraining": false,
            "forceCompletion": true,
            "provideFeedback": true,
            "trainingAttempts": 1e100
        },
        "my-bar-chart": {
            "baseComponent": "bar-chart",
            "parameters": {
                "data": [0.4, 0.3, 0.2, 0.1],
                "tags": [1, 2]
